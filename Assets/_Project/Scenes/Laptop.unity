  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Portabilidad</b>\nPC: Fija, requiere alimentaci\xF3n constante.\nLaptop:
    Port\xE1til, bater\xEDa integrada.\n\n<b>Refrigeraci\xF3n</b>\nPC: Sistema de
    enfriamiento grande, mayor eficiencia.\nLaptop: Compacto, mayor temperatura operacional.\n\n<b>Expansibilidad</b>\nPC:
    Alta. F\xE1cil agregar RAM, GPU, almacenamiento.\nLaptop: Limitada. RAM y almacenamiento
    fijos en muchos modelos.\n\n<b>Consumo energ\xE9tico</b>\nPC: Mayor consumo (200-500W
    t\xEDpico).\nLaptop: Eficiente (15-65W t\xEDpico).\n\n<b>Costo/Rendimiento</b>\nPC:
    Mejor rendimiento por precio.\nLaptop: Prima por portabilidad (+20-40% vs PC
    equivalente)."
